# Deploy target for `npm run redeploy` (copy to .env, which is gitignored).
# See scripts/redeploy.mjs.
PC_DEPLOY_HOST=your.vps.ip
PC_DEPLOY_USER=root
PC_DEPLOY_PASS=your-ssh-password

# Local macOS release signing/notarization lives in .env.apple (also gitignored);
# see scripts/release-mac.mjs for the required keys:
#   APPLE_ID, APPLE_PASSWORD (app-specific), APPLE_TEAM_ID, APPLE_SIGNING_IDENTITY,
#   TAURI_SIGNING_PRIVATE_KEY_PATH, TAURI_SIGNING_PRIVATE_KEY_PASSWORD
